            "MODIFY COLUMN `id_telecomunicaciones`          VARBINARY(50) DEFAULT NULL",
            "MODIFY COLUMN `id`                             INT(11) NOT NULL AUTO_INCREMENT",
        ];

        foreach ($alter_inventario_sqls as $sql) {
            $conn->query("ALTER TABLE $nombre_tabla $sql");
